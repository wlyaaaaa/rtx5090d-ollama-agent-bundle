{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama5090d": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama RTX 5090D",
      "options": {
        "baseURL": "http://127.0.0.1:32100/v1"
      },
      "models": {
        "qwen-main-v1": {
          "name": "Qwen Main v1 (35B, 256K)",
          "id": "qwen-main-v1",
          "reasoning": false,
          "tool_call": true,
          "temperature": true,
          "limit": { "context": 262144, "output": 8192 },
          "modalities": { "input": ["text"], "output": ["text"] }
        },
        "qwen-main-think-v1": {
          "name": "Qwen Main Think v1 (35B, 256K)",
          "id": "qwen-main-v1",
          "reasoning": true,
          "tool_call": true,
          "temperature": true,
          "limit": { "context": 262144, "output": 8192 },
          "modalities": { "input": ["text"], "output": ["text"] }
        },
        "qwen-review-v1": {
          "name": "Qwen Review v1 (27B, 128K)",
          "id": "qwen-review-v1",
          "reasoning": false,
          "tool_call": true,
          "temperature": true,
          "limit": { "context": 131072, "output": 8192 },
          "modalities": { "input": ["text"], "output": ["text"] }
        },
        "north-code-v1": {
          "name": "North Code v1 (256K)",
          "id": "north-code-v1",
          "reasoning": false,
          "tool_call": true,
          "temperature": true,
          "limit": { "context": 262144, "output": 8192 },
          "modalities": { "input": ["text"], "output": ["text"] }
        }
      }
    }
  },
  "model": "ollama5090d/qwen-main-v1"
}
