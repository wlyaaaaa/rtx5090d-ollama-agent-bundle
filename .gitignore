# Local backup snapshots can contain API keys, bot tokens, and private session traces.
results/backup-*/
results/backups/

# Runtime logs and transient service output.
results/ollama-service/
results/logs/
*.log

# Raw RTX 5090D benchmark/stability evidence stays local until summarized.
results/benchmarks/bench_5090d_*.json
results/benchmarks/bench_5090d_*.jsonl
results/benchmarks/bench_5090d_*.csv
results/benchmarks/bench_5090d_*.txt
results/stability/**
!results/benchmarks/rtx5090d_public_summary.json
!results/benchmarks/rtx5090d_public_summary.md

# Disposable smoke-test repositories and caches.
results/opencode-smoke-repo/
results/smoke/
scripts/__pycache__/
__pycache__/

# Local editor and OS metadata.
.DS_Store
Thumbs.db
desktop.ini
~$*.docx

# Local configuration backups created while tuning clients.
*.bak
*.bak.*

# Never commit Ollama model storage if this repo is placed near the model root.
blobs/
manifests/
models/
.ollama/
